# ميزان MIZAN — نموذج متغيّرات البيئة (انسخه إلى .env واملأ القيم)
# cp .env.example .env   ·   هذا الملف بلا أسرار وآمن للرفع.

# الواجهة: عنوان الـ API الحيّ (اتركه فارغاً للبيانات الساكنة في web/public/data)
NEXT_PUBLIC_API_URL=http://localhost:8000

# GRACE الحقيقي (tools/fetch_grace.py): token من https://urs.earthdata.nasa.gov
MIZAN_ED_TOKEN=

# backend (اختياري)
# MIZAN_DATA_DIR=
# MIZAN_CORS_ORIGINS=

# GEE (geo/ اختياري)
# EE_PROJECT=mizan-vcoders

# النشر الساكن (CI فقط)
# MIZAN_STATIC_EXPORT=1
# NEXT_PUBLIC_BASE_PATH=/mizan
